# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=
PORT=3000
VITE_API_URL=

# ── Yoco Payments ─────────────────────────────────────────────────────────────
YOCO_SECRET_KEY=
YOCO_PUBLIC_KEY=
YOCO_WEBHOOK_SECRET=

# ── Upstash Redis (order storage + idempotency) ──────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=whatsapp:+27XXXXXXXXX

# ── Zoho OAuth ────────────────────────────────────────────────────────────────
# Get from: https://api-console.zoho.com → Self Client
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_REGION=com
ZOHO_INVENTORY_ORG_ID=

# ── SMTP Email ────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ── Business Info ─────────────────────────────────────────────────────────────
BUSINESS_NAME=Grab & Go ZA
BUSINESS_EMAIL=
BUSINESS_PHONE=
BUSINESS_ADDRESS=
BUSINESS_CITY=
BUSINESS_PROVINCE=
BUSINESS_POSTAL_CODE=

# ── WhatsApp Cloud API (Meta Business) — legacy ──────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Shiplogic ─────────────────────────────────────────────────────────────────
SHIPLOGIC_API_KEY=
SHIPLOGIC_BASE_URL=https://api.shiplogic.com
SHIPLOGIC_TEST_MODE=true

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_KEY=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Internal Auth ─────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=

# ── Webhooks (token-based) ────────────────────────────────────────────────────
WEBHOOK_SECRET_ZOHO=
WEBHOOK_SECRET_SHIPLOGIC=

# ── Dev ───────────────────────────────────────────────────────────────────────
DISABLE_HMR=