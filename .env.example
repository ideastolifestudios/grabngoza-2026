# ===== DEPLOYMENT =====
NODE_ENV=production
APP_URL=https://grabngoza-2026.vercel.app/
PORT=5000

# ===== PAYMENT GATEWAY (Yoco) =====
YOCO_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
YOCO_PUBLIC_KEY=pk_live_xxx_or_pk_test_xxx

# ===== EMAIL/SMTP Configuration =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false

# ===== BUSINESS INFO =====
BUSINESS_EMAIL=orders@yourdomain.com
BUSINESS_PHONE=+27691630778
BUSINESS_ADDRESS=1104 Tugela Sreet, Klipfontein View
BUSINESS_CITY=Midrand
BUSINESS_PROVINCE=Gauteng
BUSINESS_POSTAL_CODE=1685

# ===== WHATSAPP INTEGRATION =====
WHATSAPP_ACCESS_TOKEN=your_whatsapp_business_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# ===== SHIPMENT/LOGISTICS =====
SHIPLOGIC_API_KEY=your_shiplogic_api_key
SHIPLOGIC_BASE_URL=https://api.shiplogic.com/v2
SHIPLOGIC_TEST_MODE=true

# ===== FIREBASE (Auto-configured in code) =====
VITE_FIREBASE_API_KEY=xxx
VITE_FIREBASE_AUTH_DOMAIN=xxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=xxx
VITE_FIREBASE_STORAGE_BUCKET=xxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=xxx
VITE_FIREBASE_APP_ID=xxx

# ===== DEVELOPMENT =====
DISABLE_HMR=false