# ─────────────────────────────────────────────────────────────
# Grab n Go — Environment Variables (Production Reference)
# Copy to .env.local for local dev. Set all in Vercel dashboard.
# NEVER commit real values. NEVER prefix secrets with VITE_ 
# (VITE_ vars are bundled into the frontend JS and become public).
# ─────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=production
# The canonical production URL — used to build Yoco redirect URLs
# Must NOT have a trailing slash. E.g.: https://shopgrabngo.co.za
SITE_URL=

# ─── Yoco ────────────────────────────────────────────────────
# Secret key — server-side only, NEVER prefix with VITE_
YOCO_SECRET_KEY=
# Public key — safe to expose to frontend (used in Yoco.js if needed)
VITE_YOCO_PUBLIC_KEY=
# Webhook signing secret — get from Yoco dashboard → Webhooks
YOCO_WEBHOOK_SECRET=

# ─── Upstash Redis ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Admin API ───────────────────────────────────────────────
# Protects GET /api/orders — use a strong random string (32+ chars)
ADMIN_API_KEY=

# ─── Zoho CRM ────────────────────────────────────────────────
# OAuth access token — rotate regularly or use server-to-server OAuth
ZOHO_ACCESS_TOKEN=
# Zoho domain (default: crm.zoho.com — may differ per region)
ZOHO_DOMAIN=crm.zoho.com

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
# Admin WhatsApp number to receive order notifications (E.164 format)
# E.g.: 27821234567 (no + prefix for Meta API)
WHATSAPP_ADMIN_NUMBER=

# ─── Email (SMTP / Zoho Mail / Nodemailer) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
BUSINESS_EMAIL=

# ─── Business Details ────────────────────────────────────────
BUSINESS_PHONE=
BUSINESS_ADDRESS=
BUSINESS_CITY=
BUSINESS_PROVINCE=
BUSINESS_POSTAL_CODE=

# ─── Firebase (frontend config — VITE_ prefix is OK here) ───
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Shiplogic (optional) ────────────────────────────────────
SHIPLOGIC_API_KEY=
SHIPLOGIC_BASE_URL=https://api.shiplogic.com
SHIPLOGIC_TEST_MODE=false
