# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=
PORT=3000
VITE_API_URL=

# ── Yoco Payments ─────────────────────────────────────────────────────────────
YOCO_SECRET_KEY=
YOCO_PUBLIC_KEY=

# ── SMTP Email ────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ── Business Info ─────────────────────────────────────────────────────────────
BUSINESS_NAME=Grab & Go ZA
BUSINESS_EMAIL=
BUSINESS_PHONE=
BUSINESS_ADDRESS=
BUSINESS_CITY=
BUSINESS_PROVINCE=
BUSINESS_POSTAL_CODE=

# ── WhatsApp Cloud API (Meta Business) ───────────────────────────────────────
# Get these from: https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── Cloudinary (replaces local disk uploads — required on Vercel) ─────────────
# Get these from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Shiplogic (SA courier rates + shipments + labels) ─────────────────────────
# Get your key from: https://shiplogic.com → Settings → API
SHIPLOGIC_API_KEY=
SHIPLOGIC_BASE_URL=https://api.shiplogic.com
SHIPLOGIC_TEST_MODE=true

# ── Firebase ──────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Dev ───────────────────────────────────────────────────────────────────────
DISABLE_HMR=
