{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "soldBy": { "type": "string" },
        "soldByLogo": { "type": "string" },
        "isDrop": { "type": "boolean" },
        "isBundle": { "type": "boolean" },
        "description": { "type": "string" },
        "weight": { "type": "number" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "required": ["name", "price", "category", "image", "description"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "completed", "cancelled"] },
        "date": { "type": "string" },
        "deliveryMethod": { "type": "string", "enum": ["ship", "pickup"] },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "postalCode": { "type": "string" },
        "phone": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "trackingUrl": { "type": "string" },
        "labelUrl": { "type": "string" }
      },
      "required": ["email", "firstName", "lastName", "items", "total", "status", "date", "deliveryMethod"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["email", "firstName", "lastName", "role"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
