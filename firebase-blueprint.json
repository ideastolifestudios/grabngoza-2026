{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "soldBy": { "type": "string" },
        "soldByLogo": { "type": "string" },
        "isDrop": { "type": "boolean" },
        "isBundle": { "type": "boolean" },
        "description": { "type": "string" },
        "weight": { "type": "number" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "required": ["id", "name", "price", "image", "category", "description"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["id", "email", "firstName", "lastName", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "completed", "cancelled", "returned"] },
        "date": { "type": "string", "format": "date-time" },
        "deliveryMethod": { "type": "string", "enum": ["standard", "pickup", "international"] },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "postalCode": { "type": "string" },
        "country": { "type": "string" },
        "phone": { "type": "string" },
        "shippingCost": { "type": "number" }
      },
      "required": ["id", "email", "firstName", "lastName", "items", "total", "status", "date", "deliveryMethod"]
    },
    "ReturnRequest": {
      "title": "ReturnRequest",
      "description": "A request to return items from an order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "items": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "completed"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "orderId", "email", "items", "status", "date"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/returnRequests/{requestId}": {
      "schema": "ReturnRequest",
      "description": "Return requests"
    }
  }
}
